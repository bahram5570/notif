{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "types": ["./assets"],
    "paths": {
      "@app/*": ["./src/app/*"],
      "@lib/*": ["./src/lib/*"],
      "@utils/*": ["./src/utils/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@assets/*": ["./public/assets/*"],
      "@services/*": ["./src/services/*"],
      "@providers/*": ["./src/providers/*"],
      "@constants/*": ["./src/constants/*"],
      "@components/*": ["./src/components/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true,
    "strictNullChecks": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "dist-maker-file.mts",
    "dist-maker-file.js"
  ],
  "exclude": ["node_modules"]
}
