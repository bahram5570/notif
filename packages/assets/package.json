{
  "name": "@repo/assets",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "web:clear": "rimraf ../../apps/web/public/assets/shared",
    "web:copy": "cpy ./src/** ../../apps/web/public/assets/shared",
    "pwa:clear": "rimraf ../../apps/pwa/public/assets/shared",
    "pwa:copy": "cpy ./src/** ../../apps/pwa/public/assets/shared",
    "build": "npm run web:clear && npm run pwa:clear && npm run web:copy && npm run pwa:copy"
  }
}
