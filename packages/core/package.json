{
  "name": "@repo/core",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    "./utils/*": {
      "import": "./dist/utils/*/index.js",
      "types": "./dist/utils/*/index.d.ts"
    },
    "./hooks/*": {
      "import": "./dist/hooks/*/index.js",
      "types": "./dist/hooks/*/index.d.ts"
    },
    "./providers/*": {
      "import": "./dist/providers/*/index.js",
      "types": "./dist/providers/*/index.d.ts"
    },
    "./components/*": {
      "import": "./dist/components/*/index.js",
      "types": "./dist/components/*/index.d.ts"
    },
    "./theme/*": {
      "import": "./dist/theme/*.js",
      "types": "./dist/theme/*.d.ts"
    },
    "./theme.css": "./dist/theme/theme.css",
    "./theme.tailwind.css": "./dist/theme/tailwind.css"
  },
  "scripts": {
    "clear:dist": "rimraf dist",
    "copy:theme.css": "cpy ./src/theme/theme.css ./dist/theme --flat",
    "copy:tailwind.config": "cpy ./src/theme/tailwind.config.ts ./dist/theme --flat",
    "build:tailwind.css": "cd ./src/theme && tailwindcss -i ./tailwind.css -o ../../dist/theme/tailwind.css",
    "build": "npm run clear:dist && tsc --project tsconfig.json && npm run copy:tailwind.config && npm run copy:theme.css && npm run build:tailwind.css"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
