{
  "name": "@repo/core",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    "./utils/*": {
      "import": "./dist/utils/*/index.js",
      "types": "./dist/utils/*/index.d.ts"
    },
    "./hooks/*": {
      "import": "./dist/hooks/*/index.js",
      "types": "./dist/hooks/*/index.d.ts"
    },
    "./providers/*": {
      "import": "./dist/providers/*/index.js",
      "types": "./dist/providers/*/index.d.ts"
    },
    "./components/*": {
      "import": "./dist/components/*/index.js",
      "types": "./dist/components/*/index.d.ts"
    },
    "./theme/*": {
      "import": "./dist/theme/*.js",
      "types": "./dist/theme/*.d.ts"
    },
    "./theme.css": "./dist/theme/theme.css",
    "./theme.tailwind.config.css": "./dist/theme/tailwind.config.css"
  },
  "scripts": {
    "clear:dist": "rimraf dist",
    "copy:theme": "cpy ./src/theme/theme.css !./src/theme/tailwind.config.css ./dist/theme --flat",
    "copy:tailwind-styles": "cd ./src/theme && tailwindcss -i ./tailwind.config.css -o ../../dist/theme/tailwind.config.css",
    "build": "npm run clear:dist && npm run copy:theme && npm run copy:tailwind-styles && tsc --project tsconfig.json"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
