{
  "name": "@repo/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./utils/*": {
      "import": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    },
    "./constants/*": {
      "import": "./dist/constants/*.js",
      "types": "./dist/constants/*.d.ts"
    },
    "./hooks/*": {
      "import": "./dist/hooks/*/*.js",
      "types": "./dist/hooks/*/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json"
  }
}
