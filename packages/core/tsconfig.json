{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,
    "types": ["./assets"],
    "emitDeclarationOnly": false,
    "paths": {
      "@assets/*": ["../assets/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/theme/tailwind.config.ts"]
}
