{
  "name": "@repo/components",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./styles.css": {
      "import": "./dist/styles/index.css",
      "default": "./dist/styles/index.css"
    },
    "./ui/*": {
      "import": "./dist/ui/*/index.js",
      "types": "./dist/ui/*/index.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc --project tsconfig.json && tailwindcss -i ./src/styles.css -o ./dist/styles/index.css"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
