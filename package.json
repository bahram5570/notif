{
  "name": "my-turborepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write .",

    "build:components": "cd packages/components && npm run build",
    "build:assets": "cd packages/assets && npm run build",
    "build:core": "cd packages/core && npm run build",

    "build:pwa": "npm run build:assets && npm run build:core && npm run build:components && cd apps/pwa && npm run build",
    "start:pwa": "cd apps/pwa && npm run start",
    "dev:pwa": "cd apps/pwa && npm run dev"


  },
  "dependencies": {
    "@types/react": "^18.3.23",
    "eslint-plugin-jest": "^28.6.0",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^14.2.5",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "turbo": "^2.5.5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
