{
  "name": "impo-apps",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "core:build": "cd packages/core && npm run build",
    "copies:build": "cd packages/copies && npm run build",
    "packages:build": "npm run copies:build && npm run core:build",
    "web:build": "npm run packages:build && cd apps/web && npm install && npm run build",
    "web:vercel:build": "npm run packages:build && cd apps/web && npm run build",
    "web:export": "cd apps/web && npm run export",
    "web:install": "cd apps/web && npm install",
    "web:start": "cd apps/web && npm run start",
    "web:dev": "cd apps/web && npm run dev",
    "pwa:build": "npm run packages:build && cd apps/pwa && npm install && npm run build",
    "pwa:vercel:build": "npm run packages:build && cd apps/pwa && npm install && npm run build",
    "pwa:export": "cd apps/pwa && npm run export",
    "pwa:start": "cd apps/pwa && npm run start",
    "pwa:install": "cd apps/pwa && npm install",
    "pwa:dev": "cd apps/pwa && npm run dev",
    "men-pwa:build": "npm run packages:build && cd apps/men-pwa && npm install && npm run build",
    "men-pwa:vercel:build": "npm run packages:build && cd apps/men-pwa && npm install && npm run build",
    "men-pwa:export": "cd apps/men-pwa && npm run export",
    "men-pwa:start": "cd apps/men-pwa && npm run start",
    "men-pwa:install": "cd apps/men-pwa && npm install",
    "men-pwa:dev": "cd apps/men-pwa && npm run dev"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.8.6",
    "@sentry/nextjs": "^10.30.0",
    "@tanstack/react-query": "^5.55.4",
    "@tanstack/react-query-devtools": "^5.55.4",
    "browser-image-compression": "^2.0.2",
    "dotenv": "^17.4.2",
    "eslint-plugin-jest": "^28.6.0",
    "eventsource": "^4.0.0",
    "firebase": "^11.6.0",
    "fs-extra": "^11.3.1",
    "glob": "^13.0.1",
    "heic-convert": "^2.1.0",
    "html-to-image": "^1.11.13",
    "js-cookie": "^3.0.5",
    "jspdf": "^2.5.2",
    "lottie-react": "^2.4.0",
    "moment-jalaali": "^0.10.1",
    "next": "14.2.5",
    "posthog-js": "^1.261.0",
    "posthog-node": "^5.8.1",
    "react": "^18",
    "react-dom": "^18",
    "react-intersection-observer": "^9.14.1",
    "react-markdown": "^10.1.0",
    "react-toastify": "^10.0.5",
    "rimraf": "^6.1.2",
    "sharp": "^0.33.5",
    "swiper": "^11.2.10",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^14.2.5",
    "@svgr/webpack": "^8.1.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/fs-extra": "^11.0.4",
    "@types/heic-convert": "^2.1.0",
    "@types/js-cookie": "^3.0.6",
    "@types/moment-jalaali": "^0.7.9",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/swiper": "^5.4.3",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "turbo": "^2.5.5"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
